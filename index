<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🏡 我们的看房日记 ❤️</title>
    <style>
        :root {
            --primary: #ff8fa3;
            --bg: #fff0f3;
            --card-bg: #ffffff;
            --text-main: #333333;
            --text-light: #777777;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: var(--primary);
            font-size: 28px;
            margin-bottom: 30px;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        .card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 8px 16px rgba(255, 143, 163, 0.1);
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--bg);
            padding-bottom: 10px;
            margin-bottom: 15px;
        }
        .apt-name {
            font-size: 20px;
            font-weight: bold;
            color: var(--text-main);
            text-decoration: none;
        }
        .apt-name:hover {
            color: var(--primary);
        }
        .rating {
            background: #fff3cd;
            color: #856404;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: bold;
        }
        .info-row {
            margin: 8px 0;
            font-size: 15px;
            display: flex;
            align-items: flex-start;
        }
        .info-icon {
            margin-right: 8px;
        }
        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 15px;
        }
        .tag {
            background: #e3f2fd;
            color: #1976d2;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
        }
        .tag-promo {
            background: #ffebee;
            color: #c62828;
        }
        .loading {
            text-align: center;
            color: var(--text-light);
            grid-column: 1 / -1;
        }
    </style>
</head>
<body>

    <h1>👩🏻‍💻 我们的专属看房库 🏡 ❤️</h1>
    <div class="container" id="app">
        <div class="loading">正在加载房源数据... ✨</div>
    </div>

    <script>
        // 读取同一目录下的 data.csv 文件
        fetch('data.csv')
            .then(response => response.text())
            .then(data => {
                const rows = data.split('\n');
                const container = document.getElementById('app');
                container.innerHTML = ''; 

                // 你的数据前两行是表头（分类和列名），所以我们从第三行 (i=2) 开始读取
                for (let i = 2; i < rows.length; i++) {
                    const cols = rows[i].split(',');
                    // 如果这一行没有数据，就跳过
                    if (cols.length < 10 || !cols[0].trim()) continue;

                    // 提取你的具体列数据 (对应你表格的列顺序)
                    const name = cols[0];
                    const website = cols[2];
                    const studioPrice = cols[4];
                    const b2Price = cols[5];
                    const promo = cols[6];
                    const rating = cols[9];
                    const commute = cols[10];
                    const washer = cols[11]; // 室内洗烘
                    const ac = cols[14];     // 空调取暖

                    // 生成每个公寓的卡片
                    const card = document.createElement('div');
                    card.className = 'card';
                    
                    card.innerHTML = `
                        <div class="card-header">
                            <a href="${website}" target="_blank" class="apt-name">${name} 🔗</a>
                            <span class="rating">⭐ ${rating || '暂无评分'}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-icon">💰</span>
                            <span><b>Studio:</b> ${studioPrice || '暂无'} <br> <b>2B2B:</b> ${b2Price || '暂无'}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-icon">🚗</span>
                            <span><b>通勤:</b> ${commute || '未知'}</span>
                        </div>
                        <div class="tags">
                            ${washer !== '/' && washer ? `<span class="tag">👕 ${washer}洗烘</span>` : ''}
                            ${ac !== '/' && ac ? `<span class="tag">❄️ ${ac}</span>` : ''}
                            ${promo !== '/' && promo ? `<span class="tag tag-promo">🎁 优惠: ${promo}</span>` : ''}
                        </div>
                    `;
                    container.appendChild(card);
                }
            })
            .catch(error => {
                document.getElementById('app').innerHTML = '<div class="loading">读取数据失败了，请检查 data.csv 是否上传成功 😢</div>';
                console.error('Error fetching CSV:', error);
            });
    </script>
</body>
</html>
